*# ==========================================
# 1. Project Specific Data & Heavy Files
# ==========================================
# Ignore all hydrated data, gazetteers, and manifestos
data/

# Ignore large downloaded archives
*.zip
auxiliary_data.zip

# Ignore the Arkindex database exports
*.sqlite
sciencespo-archelec-*.sqlite

# ==========================================
# 2. Python & Package Management Artifacts
# ==========================================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual Environments (uv default is .venv)
.venv/
venv/
env/
.env

# ==========================================
# 3. Jupyter Notebooks
# ==========================================
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# ==========================================
# 4. OS Specific Artifacts
# ==========================================
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# ==========================================
# 5. IDE & Editor Files
# ==========================================
.vscode/
.idea/
*.swp
*.swo